    <footer class="flex flex-col gap-6 px-5 py-10 text-center @container">
      
      <section id="contatti" class="bg-[#f0f2f5] px-4 py-8 mt-4">
        <h2 class="text-[#111418] text-[22px] font-bold leading-tight tracking-[-0.015em] mb-4">
          H&M Ristrutturazioni
        </h2>

        <div class="flex flex-col gap-2 text-[#111418] text-base font-normal leading-normal">
